#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    int N;
    scanf("%d", &N);

    int stack[100];
    int top = -1;

    for (int i = 0; i < N; i++) {
        int value;
        scanf("%d", &value);
        stack[++top] = value;
    }

    for (int i = 0; i <= top; i++) {
        for (int j = i + 1; j <= top; j++) {
            if (stack[i] < stack[j]) {
                int temp = stack[i];
                stack[i] = stack[j];
                stack[j] = temp;
            }
        }
    }

    for (int i = 0; i <= top; i++) {
        printf("%d", stack[i]);
        if (i != top)
            printf(" ");
    }

    return 0;
}
