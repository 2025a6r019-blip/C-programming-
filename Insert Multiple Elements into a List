#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    int N;
    scanf("%d", &N);

    int arr[101];
    for(int i = 0; i < N; i++) {
        scanf("%d", &arr[i]);
    }

    int K;
    scanf("%d", &K);

    for(int i = 0; i < K; i++) {
        int X, P;
        scanf("%d %d", &X, &P);

        for(int j = N; j > P; j--) {
            arr[j] = arr[j - 1];
        }

        arr[P] = X;
        N++; 
    }
    for(int i = 0; i < N; i++) {
        printf("%d ", arr[i]);
    }

    return 0;
}
