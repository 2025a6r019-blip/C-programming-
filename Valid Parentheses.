#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

#define MAX 10000

int main() {
    char s[MAX + 1];
    scanf("%s", s);

    char stack[MAX];
    int top = -1;
    int valid = 1;

    for (int i = 0; s[i] != '\0'; i++) {

        char ch = s[i];

        if (ch == '(' || ch == '{' || ch == '[') {
            stack[++top] = ch;
        }
        else {
            if (top == -1) { 
                valid = 0;
                break;
            }

            char topChar = stack[top];

            if ((ch == ')' && topChar == '(') ||
                (ch == '}' && topChar == '{') ||
                (ch == ']' && topChar == '[')) {
                top--;  // pop
            } else {
                valid = 0;
                break;
            }
        }
    }
    if (top != -1)
        valid = 0;

    if (valid)
        printf("%s is Valid", s);
    else
        printf("%s is Invalid", s);

    return 0;
}
