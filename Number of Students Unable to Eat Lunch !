#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    int n;
    scanf("%d", &n);

    int students[n], sandwiches[n];
    int c0 = 0, c1 = 0;

    for(int i = 0; i < n; i++) {
        scanf("%d", &students[i]);
        if(students[i] == 0) c0++;
        else c1++;
    }

    for(int i = 0; i < n; i++)
        scanf("%d", &sandwiches[i]);

    int size = n;

    for(int i = 0; i < n; i++) {
        if(sandwiches[i] == 0 && c0 > 0) {
            c0--;
            size--;
        }
        else if(sandwiches[i] == 1 && c1 > 0) {
            c1--;
            size--;
        }
        else break;
    }

    printf("%d\n", size);
    return 0;
}
