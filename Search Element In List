#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    int n, x;
    scanf("%d", &n);

    int arr[1000];

    for(int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }
    scanf("%d", &x);

    int found = 0;

    for(int i = 0; i < n; i++) {
        if(arr[i] == x) {
            found = 1;
            break;
        }
    }

    if(found)
        printf("Found");
    else
        printf("Not Found");
 
    return 0;
}
