#include <math.h>
#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <assert.h>
#include <limits.h>
#include <stdbool.h>

int main() {
    int n;
    scanf("%d", &n);

    int tickets[100];
    for(int i = 0; i < n; i++) {
        scanf("%d", &tickets[i]);
    }

    int k;
    scanf("%d", &k);

    int time = 0;

    while(tickets[k] > 0) {
        for(int i = 0; i < n; i++) {
            if(tickets[i] > 0) {
                tickets[i]--;
                time++;

                if(i == k && tickets[i] == 0) {
                    printf("%d\n", time);
                    return 0;
                }
            }
        }
    }

    return 0;
}
