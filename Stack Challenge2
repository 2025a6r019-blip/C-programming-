#include <stdio.h>
#include <string.h>
#include <math.h>

int stack[100];
int top = -1;
int size;

void push(int value) {
    if (top == size - 1) {
        printf("Overflow\n");
    } else {
        stack[++top] = value;
    }
}

void pop() {
    if (top == -1) {
        printf("Underflow\n");
    } else {
        printf("Popped: %d\n", stack[top]);
        top--;
    }
}

void display() {
    if (top == -1) {
        printf("Stack is Empty");
    } else {
        for (int i = top; i >= 0; i--) {
            printf("%d", stack[i]);
            if (i > 0)
                printf(" ");
        }
    }
}

int main() {
    int N, value;

    scanf("%d", &size);
    scanf("%d", &N);

    for (int i = 0; i < N; i++) {
        scanf("%d", &value);
        push(value);
    }

    for (int i = 0; i < 2; i++) {
        pop();
    }

    for (int i = 0; i < 4; i++) {
        scanf("%d", &value);
        push(value);
    }
    pop();

    for (int i = 0; i < 2; i++) {
        scanf("%d", &value);
        push(value);
    }

    for (int i = 0; i < 3; i++) {
        pop();
    }

    display();

    return 0;
}
