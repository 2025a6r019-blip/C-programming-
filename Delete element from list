#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    
    int n, x;
    scanf("%d", &n);

    int arr[100];
    for(int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    scanf("%d", &x);

    int index = -1;

    for(int i = 0; i < n; i++) {
        if(arr[i] == x) {
            index = i;
            break;
        }
    }
    if(index != -1) {
        for(int i = index; i < n - 1; i++) {
            arr[i] = arr[i + 1];
        }
        n--; 
    }

    for(int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }

    return 0;
}
