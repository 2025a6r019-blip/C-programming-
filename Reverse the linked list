struct Node {
    int data;
    struct Node* next;
};

struct Node* newNode(int x) {
    struct Node* n = malloc(sizeof(struct Node));
    n->data = x;
    n->next = NULL;
    return n;
}

struct Node* insertEnd(struct Node* head, int x) {
    if (!head) return newNode(x);
    struct Node* t = head;
    while (t->next) t = t->next;
    t->next = newNode(x);
    return head;
}

struct Node* reverse(struct Node* head) {
    struct Node *prev = NULL, *curr = head, *next;
    while (curr) {
        next = curr->next;
        curr->next = prev;
        prev = curr;
        curr = next;
    }
    return prev;
}

void display(struct Node* head) {
    while (head) {
        printf("%d ", head->data);
        head = head->next;
    }
}

int main() {
    int n, x;
    struct Node* head = NULL;

    scanf("%d", &n);
    while (n--) {
        scanf("%d", &x);
        head = insertEnd(head, x);
    }

    head = reverse(head);
    display(head);

    return 0;
}
